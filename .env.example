# =========================

# Human OSINT Pipeline

# Environment Variables

# =========================

# Copy this file to .env and fill in your own API keys.

# Do NOT commit your real .env file to GitHub.

# -------------------------

# Email Reputation Lookup

# -------------------------

# EmailRep may work without a key depending on usage limits.

# Add a key here only if you have one.

EMAILREP_API_KEY=

# -------------------------

# Breach Lookup

# -------------------------

# Used for optional breach summary checks.

# Example service: BreachDirectory through RapidAPI.

# Required only if you run the pipeline with breach checking enabled.

RAPIDAPI_KEY=

# -------------------------

# Phone Lookup

# -------------------------

# Used by modules/phone_lookup.py.

# Example service: Numverify.

# Required only if you use phone lookup.

NUMVERIFY_API_KEY=

# -------------------------

# Email Finder

# -------------------------

# Used by modules/email_finder.py.

# Example service: Hunter.io.

# Required only if you use email finder.

HUNTER_API_KEY=

# -------------------------

# Optional Output Settings

# -------------------------

# Folder where generated JSON and reports are saved.

OUTPUT_DIR=output

# Folder where generated HTML/PDF reports are saved.

REPORTS_DIR=reports

# -------------------------

# Optional Runtime Settings

# -------------------------

# Set to true only for local debugging.

DEBUG=false
